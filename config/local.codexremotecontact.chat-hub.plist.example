<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.codexremotecontact.chat-hub</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>npm</string>
    <string>start</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>
  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/runtime/logs/chat-hub.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/runtime/logs/chat-hub.err.log</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
